{
  "name": "@blitz/resolver",
  "version": "0.0.0",
  "description": "@blitz/resolver",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --sourcemap --target=browser --format=esm && tsc --emitDeclarationOnly -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json",
    "lint": "eslint . --max-warnings 0",
    "test": "bun test"
  },
  "devDependencies": {
    "bun-types": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
