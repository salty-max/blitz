{
  "name": "@blitz/ui",
  "version": "0.0.0",
  "description": "Reusable Blitz UI components in the Blood Bowl 'Spike!' aesthetic",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --sourcemap --target=browser --format=esm --packages external && tsc --emitDeclarationOnly -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-slot": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.0"
  },
  "peerDependencies": {
    "react": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "bun-types": "^1.3.13",
    "react": "^19.1.0",
    "typescript": "^6.0.3"
  }
}
