{
  "name": "blitz",
  "private": true,
  "type": "module",
  "description": "Blood Bowl toolkit: team & league management and a rules codex",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier . -w",
    "gen:keys": "bun scripts/gen-data-keys.ts",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@blitz/web",
    "dev:api": "turbo run dev --filter=@blitz/api",
    "storybook": "turbo run storybook --filter=@blitz/web",
    "build-storybook": "turbo run build-storybook",
    "commitlint": "commitlint --edit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^63.0.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unicorn": "^65.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "turbo": "^2.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "engines": {
    "node": ">=22",
    "bun": ">=1.3"
  },
  "packageManager": "bun@1.3.13"
}
