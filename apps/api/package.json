{
  "name": "@blitz/api",
  "version": "0.0.0",
  "description": "Read API over the blitz data",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target=bun --format=esm",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "bun test"
  },
  "dependencies": {
    "hono": "^4.12.25"
  },
  "devDependencies": {
    "bun-types": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
