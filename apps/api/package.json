{
  "name": "@blitz/api",
  "version": "0.0.0",
  "description": "Auth + persistence API for user-owned teams",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target=bun --format=esm",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "better-auth": "^1.6.20",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "bun-types": "^1.3.13",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
