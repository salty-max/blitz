# Postgres connection (matches docker-compose.yml; 5433 to coexist with auspex).
DATABASE_URL=postgres://blitz:blitz@localhost:5433/blitz

# Session signing secret — generate a strong, random value in production.
BETTER_AUTH_SECRET=dev-secret-change-me

# The API's own base URL.
BETTER_AUTH_URL=http://localhost:3000

# Comma-separated origins allowed to call the auth API (the web app).
TRUSTED_ORIGINS=http://localhost:5173
